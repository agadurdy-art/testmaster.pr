# =============================================================================
# .env.example — TestMaster / IELTS Ace migration template (2026-05-06)
# =============================================================================
# Backend env vars go on Railway service. Frontend env vars go on Vercel.
# Copy values from `backend/.env` (lokal) and Atlas/R2 dashboards.
# =============================================================================

# ----- Backend (Railway) -----------------------------------------------------

# MongoDB Atlas (Singapore region cluster)
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=testmaster
DB_NAME=testmaster

# CORS — comma-separated origins (Vercel app + custom domain)
CORS_ORIGINS=https://testmaster.pro,https://www.testmaster.pro,https://testmaster-pr.vercel.app

# Static asset CDN (Cloudflare R2 public URL or custom domain).
# Boş ise lokal /api/static/* servis edilir; doluysa kod buraya yönlendirir.
STATIC_BASE_URL=https://pub-fcd31e7869f94c4896d039253b8f1646.r2.dev

# LLM keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
EMERGENT_LLM_KEY=

# ElevenLabs (Liz voice + Conversational AI agent)
ELEVENLABS_API_KEY=
LIZ_VOICE_ID=
ELEVENLABS_AGENT_ID=

# Azure Speech (premium pronunciation analysis)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=southeastasia

# Feature flags
UNIFIED_SPEAKING_EVAL_ENABLED=1

# Email (transactional)
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# PayPal (production)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_API_BASE=https://api-m.paypal.com
PAYPAL_WEBHOOK_ID=
PAYPAL_WEEKLY_PLAN_ID=
PAYPAL_MONTHLY_PLAN_ID=

# Facebook OAuth (optional)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# SePay (Vietnamese bank transfer)
SEPAY_BANK_NAME=
SEPAY_ACCOUNT_NUMBER=
SEPAY_ACCOUNT_HOLDER=
SEPAY_API_KEY=

# Admin
MANUAL_CREDIT_ADMIN_TOKEN=

# R2 (Cloudflare) — only needed if backend uploads to R2 directly
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=testmaster-static
R2_ENDPOINT=https://314896334c46c9023e98ca9dfb89dedc.r2.cloudflarestorage.com

# ----- Frontend (Vercel) -----------------------------------------------------

REACT_APP_BACKEND_URL=https://api.testmaster.pro
REACT_APP_PAYPAL_CLIENT_ID=
