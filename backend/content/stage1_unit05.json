            {
              "step": 2, "type": "vocabulary",
              "items": [
                {"word": "mother", "ipa": "/ˈmʌðər/", "definition": "A female parent", "example": "This is my mother.", "image_emoji": "👩"},
                {"word": "father", "ipa": "/ˈfɑːðər/", "definition": "A male parent", "example": "This is my father.", "image_emoji": "👨"},
                {"word": "umbrella", "ipa": "/ʌmˈbrelə/", "definition": "Protects from rain (Sound U)", "example": "It is an umbrella.", "image_emoji": "☂️"},
                {"word": "van", "ipa": "/væn/", "definition": "A big car (Sound V)", "example": "I see a van.", "image_emoji": "🚐"}
              ]
            },
            {
              "step": 3, "type": "micro_game_vocab",
              "question_text": "Match the mother: 👩",
              "correct_answer": "mother", "options": ["mother", "father", "van", "umbrella"]
            },
            {
              "step": 4, "type": "micro_reading",
              "title": "At Home",
              "text": "Hello! This is my mother. She is happy. This is my father. He has a van. Look! A blue umbrella.",
              "questions": [
                {"question": "What does the father have?", "answer": "van", "options": ["van", "umbrella"]}
              ]
            },
            {
              "step": 5, "type": "grammar_focus",
              "rule_pattern": "This is my ___.",
              "explanation": "Use 'This is my' to introduce a family member.",
              "examples": ["This is my mother.", "This is my father."]
