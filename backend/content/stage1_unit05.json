            {
              "step": 7, "type": "listening",
              "audio_text": "This is my father. He is in the van.",
              "questions": [{"question": "Where is the father?", "answer": "van"}]
            },
            {
              "step": 8, "type": "production",
              "prompt": "Say: This is my mother.",
              "expected_text": "This is my mother",
              "mode": "speaking"
            },
            {
              "step": 9, "type": "exit_ticket",
              "question_text": "Sound for 🚐:",
              "correct_answer": "V", "options": ["V", "U", "T"]
