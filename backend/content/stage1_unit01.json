            {
              "step": 8, "type": "production",
              "prompt": "Say: Hello, I am a student.",
              "expected_text": "Hello, I am a student",
              "mode": "speaking"
            },
            {
              "step": 9, "type": "exit_ticket",
              "question_text": "I ___ Ben.",
              "correct_answer": "am",
              "options": ["am", "apple", "hello"]
