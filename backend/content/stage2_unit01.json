                {
                  "word": "new",
                  "ipa": "/njuː/",
                  "definition": "Not old; recently arrived",
                  "example": "This is a new book.",
                  "image_emoji": "🆕"
                },
                {
                  "word": "old",
                  "ipa": "/əʊld/",
                  "definition": "Not new; has been around",
                  "example": "It is an old story.",
                  "image_emoji": "🗝️"
                }
              ]
            },
            {
              "step": 3,
              "type": "micro_game_vocab",
              "question_text": "Match the emoji to the word: 🧑‍🤝‍🧑",
              "correct_answer": "they",
              "options": [
                "they",
                "name",
                "new",
                "old"
              ]
            },
            {
              "step": 4,
              "type": "micro_reading",
              "title": "Ben and Kim Say Hello",
              "text": "Ben and Kim are new. They are happy. Ben says, 'Hello! My name is Ben.' Kim says, 'Hi! My name is Kim.'",
              "questions": [
                {
                  "question": "Who are new?",
                  "answer": "Ben and Kim",
                  "options": [
                    "Ben and Kim",
                    "Tom and Sam",
                    "Lily and Sue"
                  ]
                }
              ]
            },
            {
              "step": 5,
              "type": "grammar_focus",
              "rule_pattern": "Who is ___? He/She/They ___.",
              "explanation": "Use He for boys, She for girls, They for more than one.",
              "examples": [
                "Who is he? He is Ben.",
                "Who are they? They are new."
              ]
            },
            {
              "step": 6,
              "type": "grammar_game",
              "mode": "word_order",
              "words": [
                "His",
                "name",
                "is",
                "Ben."
              ],
              "correct_sentence": "His name is Ben."
            },
            {
              "step": 7,
              "type": "listening",
              "audio_text": "This is Ben. He is new. This is Kim. She is new too.",
              "questions": [
                {
                  "question": "Who is new?",
                  "answer": "Ben and Kim",
                  "options": [
                    "Ben and Kim",
                    "Tom and Sam",
                    "Sue and Lily"
                  ]
                }
              ]
            },
            {
              "step": 8,
              "type": "production",
              "prompt": "Say: They are Ben and Kim.",
              "expected_text": "They are Ben and Kim.",
              "mode": "speaking"
            },
            {
              "step": 9,
              "type": "exit_ticket",
              "question_text": "Who is she?",
              "correct_answer": "Kim",
              "options": [
                "Kim",
                "Ben",
                "Tom"
              ]
            }
