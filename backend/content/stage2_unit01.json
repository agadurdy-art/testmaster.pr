      "lessons": [
        {
          "lesson_num": 1,
          "lesson_id": "stage_2_unit_01_lesson_01",
          "title": "Greetings",
          "topic": "greetings",
          "extra_links": [],
          "steps": [
            {
              "step": 1,
              "type": "warm_up",
              "question_text": "What do you say when you meet someone new?",
              "correct_answer": "Hello!",
              "options": [
                "Hello!",
                "Goodbye!",
                "Thank you!",
                "Please!"
              ],
              "image_emoji": "👋",
              "hint": "It's a polite start to talk.",
              "video_url": ""
            },
            {
              "step": 2,
              "type": "vocabulary",
              "items": [
                {
                  "word": "hello",
                  "ipa": "/həˈloʊ/",
                  "definition": "A greeting word",
                  "example": "Hello, how are you?",
                  "image_emoji": "👋"
                },
                {
                  "word": "hi",
                  "ipa": "/haɪ/",
                  "definition": "A casual greeting",
                  "example": "Hi, I'm Sam.",
                  "image_emoji": "👋"
                },
                {
                  "word": "answer",
                  "ipa": "/ˈæn.sər/",
                  "definition": "To reply to a question",
                  "example": "I answer the question.",
                  "image_emoji": "❓"
                },
                {
                  "word": "listen",
                  "ipa": "/ˈlɪs.ən/",
                  "definition": "To hear attentively",
                  "example": "Listen to the teacher.",
                  "image_emoji": "👂"
                }
              ]
            },
            {
              "step": 3,
              "type": "micro_game_vocab",
              "question_text": "Match the emoji to the word: 👋",
              "correct_answer": "hello",
              "options": [
                "hello",
                "answer",
                "listen",
                "goodbye"
              ]
            },
            {
              "step": 4,
              "type": "micro_reading",
              "title": "First Day Greeting",
              "text": "He says, 'Hello!' She says, 'Hi!' They listen and answer the teacher.",
              "questions": [
                {
                  "question": "Who said hello?",
                  "answer": "He",
                  "options": [
                    "He",
                    "She",
                    "They"
                  ]
                }
              ]
            },
            {
              "step": 5,
              "type": "grammar_focus",
              "rule_pattern": "Who is ___?",
              "explanation": "Use for asking about someone.",
              "examples": [
                "Who is he?",
                "Who is she?"
              ]
            },
            {
              "step": 6,
              "type": "grammar_game",
              "mode": "word_order",
              "words": [
                "He",
                "is",
                "the",
                "teacher"
              ],
              "correct_sentence": "He is the teacher."
            },
            {
              "step": 7,
              "type": "listening",
              "audio_text": "He says, 'Hello!' She listens. They answer.",
              "questions": [
                {
                  "question": "Who says hello?",
                  "answer": "He",
                  "options": [
                    "He",
                    "She",
                    "They"
                  ]
                }
              ]
            },
            {
              "step": 8,
              "type": "production",
              "prompt": "Say: I listen to the teacher.",
              "expected_text": "I listen to the teacher.",
              "mode": "speaking"
            },
            {
              "step": 9,
              "type": "exit_ticket",
              "question_text": "What is a way to greet?",
              "correct_answer": "Hi",
              "options": [
                "Hi",
                "Later",
                "Stop"
              ]
            }
          ]
        },
