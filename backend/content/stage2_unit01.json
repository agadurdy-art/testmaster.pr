          "topic": "greetings",
          "extra_links": [],
          "steps": [
            {
              "step": 1,
              "type": "warm_up",
              "question_text": "What do you say when you meet someone?",
              "correct_answer": "Hello",
              "options": [
                "Goodbye",
                "Hello",
                "Thanks",
                "Yes"
              ],
              "image_emoji": "👋",
              "hint": "People say this when they greet.",
              "video_url": ""
            },
            {
              "step": 2,
              "type": "vocabulary",
              "items": [
                {
                  "word": "hello",
                  "ipa": "/həˈloʊ/",
                  "definition": "A friendly greeting.",
                  "example": "Hello, my name is Tom.",
                  "image_emoji": "👋"
                }
              ]
            },
            {
              "step": 3,
              "type": "micro_game_vocab",
              "question_text": "Match the emoji to the word: 👋",
              "correct_answer": "hello",
              "options": [
                "hello",
                "goodbye",
                "please",
                "thanks"
              ]
            },
            {
              "step": 4,
              "type": "micro_reading",
              "title": "Meeting Miss Lily",
              "text": "Hello! I am Miss Lily. Who is he? He is Sam. Sam says, 'Hi!'",
              "questions": [
                {
                  "question": "Who says 'Hi!'?",
                  "answer": "Sam",
                  "options": [
                    "Miss Lily",
                    "Sam",
                    "Tom"
                  ]
                }
              ]
            },
            {
              "step": 5,
              "type": "grammar_focus",
              "rule_pattern": "Who is ___?",
              "explanation": "Ask about someone using 'Who is'.",
              "examples": [
                "Who is he?",
                "Who is she?"
              ]
            },
            {
              "step": 6,
              "type": "grammar_game",
              "mode": "word_order",
              "words": [
                "he",
                "Who",
                "is",
                "?"
              ],
              "correct_sentence": "Who is he?"
            },
            {
              "step": 7,
              "type": "listening",
              "audio_text": "Hi! They are my friends. She is Anna.",
              "questions": [
                {
                  "question": "Who is Anna?",
                  "answer": "She",
                  "options": [
                    "He",
                    "She",
                    "They"
                  ]
                }
              ]
            },
            {
              "step": 8,
              "type": "production",
              "prompt": "Say: Hello! Who is she?",
              "expected_text": "Hello! Who is she?",
              "mode": "speaking"
            },
            {
              "step": 9,
              "type": "exit_ticket",
              "question_text": "How do you greet someone?",
              "correct_answer": "Hello",
              "options": [
                "Bye",
                "Hello",
                "Thanks"
              ]
            }
          ]
